{
	"name": "svelte-tel-input",
	"description": "svelte-tel-input",
	"version": "4.2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gyurielf/svelte-tel-input.git"
	},
	"homepage": "https://github.com/gyurielf/svelte-tel-input#readme",
	"keywords": [
		"svelte",
		"svelte kit",
		"sveltekit",
		"tel input",
		"phone",
		"phone input",
		"svelte phone input",
		"svelte tel input",
		"intl",
		"intl tel input",
		"svelte intl tel input"
	],
	"engines": {
		"npm": ">= 10",
		"yarn": ">= 1",
		"node": ">= 22",
		"pnpm": ">= 10"
	},
	"scripts": {
		"check:publint": "publint . --strict",
		"convert": "node ./scripts/convertExamples.js",
		"package:watch": "svelte-kit sync && svelte-package --watch",
		"package": "svelte-kit sync && pnpm run convert && svelte-package && pnpm run check:publint",
		"svelte-check": "svelte-kit sync && svelte-check --ignore 'dist,build,coverage,.svelte-kit,package' --fail-on-warnings --no-tsconfig",
		"sync": "svelte-kit sync",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"ts": "tsc --noEmit"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"libphonenumber-js": "1.12.42"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/micromatch": "^4.0.10",
		"@types/node": "^22.17.0",
		"dotenv": "^17.4.2",
		"jsdom": "^29.0.2",
		"micromatch": "^4.0.8",
		"postcss": "^8.5.10",
		"publint": "^0.3.18",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte2tsx": "^0.7.53",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"valibot": "^1.3.1",
		"vite": "^7.3.2",
		"vitest": "^4.1.5",
		"zod": "^4.3.6"
	},
	"type": "module",
	"license": "MIT",
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"typesVersions": {
		"*": {
			"types": [
				"./dist/types/index.d.ts"
			],
			"utils": [
				"./dist/utils/index.d.ts"
			],
			"assets": [
				"./dist/assets/index.d.ts"
			],
			"validators": [
				"./dist/validators/index.d.ts"
			]
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/types/index.d.ts"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"default": "./dist/utils/index.js"
		},
		"./assets": {
			"types": "./dist/assets/index.d.ts",
			"default": "./dist/assets/index.js"
		},
		"./validators": {
			"types": "./dist/validators/index.d.ts",
			"default": "./dist/validators/index.js"
		},
		"./styles/flags.css": "./dist/styles/flags.css"
	}
}
